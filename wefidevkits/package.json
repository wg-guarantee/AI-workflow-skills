{
  "name": "wefidevkits",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-skills.mjs",
    "validate": "node scripts/validate-skills.mjs",
    "build": "node scripts/generate-skills.mjs && node scripts/validate-skills.mjs",
    "install:user": "npm run build && node scripts/install-claude.mjs --target user",
    "install:project": "npm run build && node scripts/install-claude.mjs --target project",
    "install:claude:user": "npm run install:user",
    "install:claude:project": "npm run install:project",
    "package:claude-plugin": "node scripts/package-claude-plugin.mjs",
    "set:claude:commit-mode": "node scripts/set-commit-mode.mjs"
  }
}
